# --- Supabase (get these from your Supabase project: Settings > API) ---
# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY. Never import into a client component. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SERVER-ONLY. Shared password for the owner/admin login.
ADMIN_PASSWORD=changeme-admin

# Secret used to sign admin/scorekeeper session cookies (any long random string).
SESSION_SECRET=change-this-to-a-long-random-string
